NODE_ENV=test
APP_PORT=3001
APP_HOST=0.0.0.0
APP_LOG_LEVEL=error
DATABASE_URL=postgresql://leanstock:leanstock_pass@localhost:5432/leanstock_test
JWT_SECRET=test-jwt-secret-min-32-chars-for-testing-only
JWT_REFRESH_SECRET=test-refresh-secret-min-32-chars-for-testing-only
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:3001
RATE_LIMIT_AUTH_MAX=100
RATE_LIMIT_AUTH_WINDOW_MS=60000
BCRYPT_ROUNDS=4
DEAD_STOCK_THRESHOLD_DAYS=30
DEAD_STOCK_DECAY_PERCENT=10
DEAD_STOCK_DECAY_MAX_PERCENT=50
CRON_ENABLED=false
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
SYSTEM_USER_ID=system
REDIS_URL=redis://localhost:6379
REDIS_REQUIRED=false
EMAIL_PROVIDER=mock
EMAIL_FROM=LeanStock <no-reply@leanstock.local>
APP_BASE_URL=http://localhost:3001
