# ========== NODE & APP ==========
NODE_ENV=development
APP_PORT=3000
APP_HOST=0.0.0.0
APP_LOG_LEVEL=info
APP_BASE_URL=http://localhost:3000

# ========== DATABASE ==========
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://leanstock:leanstock_pass@localhost:5432/leanstock

# ========== JWT SECURITY ==========
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=your-super-secret-key-min-32-chars-change-this-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-min-32-chars-change-this-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ========== CORS (comma-separated, NO wildcard in prod) ==========
CORS_ORIGIN=http://localhost:3001

# ========== RATE LIMITING ==========
RATE_LIMIT_AUTH_MAX=5
RATE_LIMIT_AUTH_WINDOW_MS=60000

# ========== SECURITY ==========
BCRYPT_ROUNDS=12

# ========== ASYNC JOBS / REDIS ==========
REDIS_URL=redis://localhost:6379
REDIS_REQUIRED=false
QUEUE_EMAIL_NAME=leanstock:queue:email
QUEUE_DECAY_NAME=leanstock:queue:decay
QUEUE_POLL_TIMEOUT_SECONDS=5

# ========== EMAIL DELIVERY ==========
# Use "mock" for local/dev. Use "sendgrid" for real third-party delivery.
EMAIL_PROVIDER=mock
EMAIL_FROM=LeanStock <no-reply@leanstock.local>
SENDGRID_API_KEY=
EMAIL_VERIFICATION_TTL_MINUTES=1440
PASSWORD_RESET_TTL_MINUTES=30

# ========== DEAD STOCK DECAY ==========
DEAD_STOCK_THRESHOLD_DAYS=30
DEAD_STOCK_DECAY_PERCENT=10
DEAD_STOCK_DECAY_MAX_PERCENT=50
CRON_ENABLED=true
DEAD_STOCK_DECAY_SCHEDULE=0 2 * * *
SYSTEM_USER_ID=system

# ========== PAGINATION ==========
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
